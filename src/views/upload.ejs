<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mirrors</title>
    <link rel="stylesheet" href="/public/css/uploadPage.css">
    <link rel="stylesheet" href="/public/css/mainPage.css">

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&family=Noto+Sans:wght@400;500;700;900&display=swap"
    />
  </head>
  <body class="bg-gray-50 text-gray-900">
    <div class="layout-container bg-white">
      <!-- <header>
        <div class="logo">
          <svg
            class="logo-icon"
            fill="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              clip-rule="evenodd"
              d="M3 3H10V10H17V17H24V24H3V3ZM5 5V22H22V19H15V12H8V5H5Z"
              fill-rule="evenodd"
            ></path>
          </svg>
          <h2 class="logo-text">Mirrors</h2>
