<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Image Search</title>
  <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&family=Noto+Sans:wght@400;500;700;900&display=swap"
  />
  <link rel="stylesheet" href="/public/css/mainPage.css">
</head>

<body class="bg-gray-50 text-gray-900">
  <div class="layout-container">
    <header>
      <div class="logo-container">
        <svg class="logo-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path clip-rule="evenodd" d="M3 3H10V10H17V17H24V24H3V3ZM5 5V22H22V19H15V12H8V5H5Z" fill-rule="evenodd"></path>
        </svg>
        <h2 class="logo-text">Mirrors</h2>
      </div>
      <nav>
        <a href="/upload">Upload</a>
        <a class="active" href="/">Search</a>
      </nav>
    </header>

    <main>
      <div class="search-container">
        <div class="text-center">
          <h1 id="Banner">Find Your Images</h1>
          <p>
            Search through your folders to find the image you're looking for.
          </p>
        </div>
        <div class="search-box-container">
          <div class="search-box">
            <div class="dropdown-container">
              <button class="dropdown-button" id="dropdown-btn">
                <span id="selected-folder">All Folders</span>
                <svg aria-hidden="true" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg">
                  <path clip-rule="evenodd"
                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                    fill-rule="evenodd"></path>
                </svg>
              </button>
              <ul class="dropdown-menu" id="dropdown-menu" role="menu" aria-labelledby="dropdown-btn">
                <li><a href="#" data-folder="All Folders">All Folders</a></li>
                <li>
                  <a href="#" data-folder="Landscapes">Landscapes</a>
                </li>
                <li><a href="#" data-folder="Nature">Nature</a></li>
                <li><a href="#" data-folder="Sunsets">Sunsets</a></li>
              </ul>
            </div>
            <div class="divider"></div>
            <div class="search-input-wrapper">
              <textarea class="search-input" placeholder="Search by description..." rows="1"></textarea>
              <button class="search-button" id="search-btn">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path clip-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"
                    fill-rule="evenodd"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>

    <div class="modal-overlay" id="modal-overlay">
